*~

# Build output — produced by scripts/build.py, never committed.
# CI rebuilds it on every push (deterministically, via SOURCE_DATE_EPOCH)
# and deploys it to GitHub Pages + signs it on release. Contributors can
# build locally to smoke-test but should never stage the result.
docs/index.html
# `docs/index.test.html` is the test-only sibling produced by
# `scripts/build.py --test-api` (used by the Playwright e2e suite). It
# embeds `window.__loupeTest` and must never be committed or shipped.
docs/index.test.html
loupe.html
loupe.html.sha256
loupe.html.sigstore

# Generated SBOM + release artefacts (emitted by scripts/generate_sbom.py
# and the release workflow; built into dist/ locally)
dist/
loupe.cdx.json
loupe.cdx.json.sigstore

# Generated files (optional machine-readable codemap)
codemap.json

# agents
AGENTS.md
.clinerules
.agents
.opencode

# Todo / Plans
TODO.md
PLAN.md
ARCHITECTURAL_REVIEW.md
plans/
.mcp.json

# Node / ESLint (CI-only — Loupe has no npm dependencies)
node_modules/
eslint-out.txt
.eslintcache

# Playwright e2e test artefacts (produced by `python make.py test-e2e`).
# `dist/test-deps/` already covered by the `dist/` rule above; these are
# the per-run output directories.
test-results/
playwright-report/
.last-run.json

# Logs
logs_*

# Stuff
serve.sh
